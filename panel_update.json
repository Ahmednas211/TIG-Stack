        "metricNamespace": "microsoft.network/loadbalancers",
        "metricName": "SYNCount",
        "dimensionFilters": [],
        "resources": [
          {
            "metricNamespace": "microsoft.network/loadbalancers",
            "resourceGroup": "$ResourceGroup",
            "resourceName": "$ResourceName",
            "subscription": "7852edc2-4695-44f2-812f-a927308fbfa0"
          }
        ]
      }
    }
  ],
  "transformations": [
    {
      "id": "reduce",
      "options": {
        "reducers": ["last"],
        "includeTimeField": false,
        "mode": "seriesToRows"
      }
    },
    {
      "id": "merge",
      "options": {}
    },
    {
      "id": "organize",
      "options": {
